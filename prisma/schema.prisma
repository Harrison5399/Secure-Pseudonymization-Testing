generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Development/test database for encrypted map blobs.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Logical grouping for anonymization/deanonymization sessions.
model Conversation {
  id        String         @id @default(cuid())
  label     String?
  createdAt DateTime       @default(now())
  maps      EncryptedMap[]
}

// Backend stores only encrypted payload metadata, never plaintext map values.
model EncryptedMap {
  id             String       @id @default(cuid())
  conversationId String
  method         String
  ciphertext     String
  iv             String
  salt           String
  iterations     Int
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Blind storage table for client-side encrypted envelope bundles.
// Server can query blobs by user but cannot decrypt their contents.
model EncryptedBlob {
  id        String   @default(cuid())
  userId    String
  bundle    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([id, userId])
  @@index([userId, updatedAt])
}

// Auth.js adapter models for persisted users, accounts, and sessions.
model User {
  id             String          @id @default(cuid())
  username       String          @unique
  name           String?
  email          String          @unique
  passwordHash   String?
  emailVerified  DateTime?
  image          String?
  accounts       Account[]
  sessions       Session[]
  publicKey      UserPublicKey?
  deviceKeys     UserDeviceKey[]
  encryptedBlobs EncryptedBlob[]
  sentMessages   Message[]       @relation("MessageSender")
  receivedMessages Message[]     @relation("MessageRecipient")
}

// Public key directory for email-based E2EE demo messaging.
// Private keys are never stored server-side.
model UserPublicKey {
  id                String   @id @default(cuid())
  userId            String   @unique
  identityPublicB64 String
  algorithm         String   @default("X25519")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identityPublicB64])
}

// Multi-device public key directory. One active public key per user-device.
model UserDeviceKey {
  id                String   @id @default(cuid())
  userId            String
  deviceId          String
  identityPublicB64 String
  algorithm         String   @default("X25519")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId, updatedAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id            String   @id @default(cuid())
  sessionToken  String   @unique
  userId        String
  expires       DateTime
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier  String
  token       String   @unique
  expires     DateTime

  @@unique([identifier, token])
}

// User-to-user demo messages to validate identity-bound storage and access controls.
model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  content     String
  createdAt   DateTime @default(now())
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt])
  @@index([senderId, createdAt])
}
